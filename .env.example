# Shared
DATABASE_URL=
OPENAI_API_KEY=

# Agent app
LEADPILOT_MODEL_PROVIDER=openai
LEADPILOT_AGENT_MODEL=gpt-4.1-mini
LEADPILOT_MODEL_CONTEXT_WINDOW_TOKENS=
LEADPILOT_COMPACTION_THRESHOLD_PERCENT=0.8
LEADPILOT_THINKING=off
LEADPILOT_MODEL_TIMEOUT_MS=25000
LEADPILOT_CLIENT_TURN_TIMEOUT_MS=45000
FIRM_EMBEDDING_QUERY_TIMEOUT_MS=12000
LEGAL_EMBEDDING_QUERY_TIMEOUT_MS=12000
LEADPILOT_THINKING_BUDGET_TOKENS=4096
LEADPILOT_DEV_FIRM_SLUG=demo-law
# Required for split-origin prod (Vercel web → Render agent):
# LEADPILOT_PUBLIC_CHAT=true
# LEADPILOT_ALLOWED_ORIGINS=https://leadpilot-demo-web.vercel.app
LEADPILOT_DISABLE_ADMIN_PROVISIONING=true

# Staff analytics
# LEADPILOT_STAFF_ANALYTICS=true
# LEADPILOT_STAFF_FIRM_ID=demo-law

# Knowledge base
FIRM_KB_EMBEDDING_MODEL=text-embedding-3-small
FIRM_KB_EMBEDDING_DIMENSIONS=1536
FIRM_KB_EMBEDDING_BATCH_SIZE=96

# Observability
# LEADPILOT_OBSERVABILITY=false
# LEADPILOT_OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=
